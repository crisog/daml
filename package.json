{
  "name": "daml-playground",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler deploy",
    "deploy:fresh": "docker builder prune -f && npm run build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "types:check": "fumadocs-mdx && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "lint": "biome check",
    "format": "biome format --write",
    "sync:daml-syntax": "cp external/daml/sdk/compiler/daml-extension/syntaxes/daml.json syntaxes/daml.json && echo 'Synced daml.json from external/daml'"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@cloudflare/containers": "^0.2.3",
    "@monaco-editor/react": "^4.7.0",
    "@tanstack/react-router": "1.167.5",
    "@tanstack/react-router-devtools": "1.166.9",
    "@tanstack/react-start": "1.166.17",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "better-auth": "^1.6.0",
    "drizzle-orm": "^0.45.2",
    "fumadocs-core": "16.7.0",
    "fumadocs-mdx": "14.2.11",
    "fumadocs-ui": "16.7.0",
    "lucide-react": "^0.577.0",
    "mermaid": "^11.13.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "vite": "^8.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@cloudflare/vite-plugin": "^1.31.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "wrangler": "^4.80.0"
  }
}
